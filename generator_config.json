  "type_definitions": {
    "ItemStatus": {
      "base_type": "string",
      "values": {
        "NORMAL": "ItemStatusNormal",
        "BANNED": "ItemStatusBanned",
        "UNLIST": "ItemStatusUnlist"
      }
    },
    "PromotionStatus": {
      "base_type": "string",
      "values": {
