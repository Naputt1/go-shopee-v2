    "ReturnStatus": {
      "base_type": "string",
      "values": {
        "REQUESTED": "ReturnStatusRequested",
        "ACCEPTED": "ReturnStatusAccepted",
        "CANCELLED": "ReturnStatusCancelled",
        "JUDGING": "ReturnStatusJudging",
